# Flow Past Cylinder Benchmark Domain Grid Configuration
# Single large rectangular block with characteristic boundary conditions on the left/right 
# and solid slip walls on the top/bottom.

[Block0]
X_MIN = 0.0
X_MAX = 3.0
Y_MIN = 0.0
Y_MAX = 1.0

N_ELEM_X = 480
N_ELEM_Y = 160

BC_L = CHARACTERISTIC:1.0:5.0:0.0:0.75
BC_R = CHARACTERISTIC:1.0:5.0:0.0:0.75
BC_B = WALL
BC_T = WALL
