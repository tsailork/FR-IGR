[Physics]
GAMMA = 1.4
IC_TYPE = ABC_FLOW_3D

[Solver]
P_DEG = 2
CFL = 0.35
T_FINAL = 0.5
NUM_THREADS = 8

[NavierStokes]
ENABLE_NS = true
RE = 1000.0

[Regularization]
ENABLE_IGR = false

[PPR]
ENABLE_PPR = false

[Stabilization]
ENABLE_POS_LIMITER = true
POS_LIMITER_EPS = 1e-12

[ImmersedBoundary]
ENABLE_IB = false

[IO]
OUTPUT_INTERVAL = 0.05
RESTART_INTERVAL = 5.0
RESIDUAL_INTERVAL = 0.01
PROBE_INTERVAL = 0.01
PRINT_INTERVAL = 0.05
RESTART_FILE = 
RESTART_TIME = 0.0
